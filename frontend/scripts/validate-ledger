#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path

from change_recording_lib import CHANGE_TYPES, CLAIM_STATUSES, RECORD_FIELDS, load_json, load_jsonl, resolve_workspace


LEDGER_FILES = [
    "sources.jsonl",
    "captures.jsonl",
    "artifacts.jsonl",
    "entities.jsonl",
    "claims.jsonl",
    "events.jsonl",
    "tombstones.jsonl",
]


def validate_row(path: Path, row: dict, record_ids: set[str], entity_ids: set[str], event_ids: set[str]) -> list[str]:
    errors: list[str] = []
    missing = [field for field in RECORD_FIELDS if field not in row]
    if missing:
        errors.append(f"{path}: missing fields: {', '.join(missing)}")
        return errors

    record_id = row.get("record_id")
    if not isinstance(record_id, str) or not record_id.strip():
        errors.append(f"{path}: record_id must be a non-empty string")

    change_type = row.get("change_type", "")
    if change_type not in CHANGE_TYPES:
        errors.append(f"{path}: invalid change_type '{change_type}'")

    claim_status = row.get("claim_status", "")
    if claim_status not in CLAIM_STATUSES:
        errors.append(f"{path}: invalid claim_status '{claim_status}'")
    if path.name == "claims.jsonl" and not claim_status:
        errors.append(f"{path}: claim rows must set claim_status")

    confidence = row.get("confidence")
    if not isinstance(confidence, (int, float)) or confidence < 0 or confidence > 1:
        errors.append(f"{path}: confidence must be a number between 0 and 1")

    for field_name in ("related_entity_ids", "related_event_ids"):
        value = row.get(field_name)
        if not isinstance(value, list):
            errors.append(f"{path}: {field_name} must be a list")

    supersedes = row.get("supersedes_record_id", "")
    if supersedes and supersedes not in record_ids:
        errors.append(f"{path}: supersedes_record_id '{supersedes}' was not found")

    for entity_id in row.get("related_entity_ids", []):
        if entity_id not in entity_ids:
            errors.append(f"{path}: related_entity_id '{entity_id}' was not found")
    for event_id in row.get("related_event_ids", []):
        if event_id not in event_ids:
            errors.append(f"{path}: related_event_id '{event_id}' was not found")

    quant_score = row.get("quant_score")
    if quant_score is not None:
        if not isinstance(quant_score, (int, float)) or quant_score < 0 or quant_score > 100:
            errors.append(f"{path}: quant_score must be a number between 0 and 100")
    quant_breakdown = row.get("quant_breakdown")
    if quant_breakdown is not None and not isinstance(quant_breakdown, dict):
        errors.append(f"{path}: quant_breakdown must be an object when present")

    artifact_path = row.get("artifact_path")
    if artifact_path is not None and not isinstance(artifact_path, str):
        errors.append(f"{path}: artifact_path must be a string when present")
    return errors


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate JSONL ledgers and ingest-run scaffolds.")
    parser.add_argument("--workspace", help="Research workspace root.")
    args = parser.parse_args()

    workspace = resolve_workspace(args.workspace)
    errors: list[str] = []

    manifest_path = workspace / "manifests" / "workspace.json"
    if not manifest_path.exists():
        errors.append(f"missing manifest: {manifest_path}")
    else:
        try:
            load_json(manifest_path)
        except json.JSONDecodeError as exc:
            errors.append(f"{manifest_path}: invalid JSON: {exc}")

    rows_by_file: dict[str, list[dict]] = {}
    for name in LEDGER_FILES:
        path = workspace / "ledger" / name
        if not path.exists():
            errors.append(f"missing ledger file: {path}")
            rows_by_file[name] = []
            continue
        try:
            rows_by_file[name] = load_jsonl(path)
        except ValueError as exc:
            errors.append(str(exc))
            rows_by_file[name] = []

    entity_ids = {row.get("record_id", "") for row in rows_by_file.get("entities.jsonl", [])}
    event_ids = {row.get("record_id", "") for row in rows_by_file.get("events.jsonl", [])}
    record_ids: set[str] = set()
    duplicates: set[str] = set()
    for name, rows in rows_by_file.items():
        for row in rows:
            record_id = row.get("record_id", "")
            if record_id in record_ids:
                duplicates.add(record_id)
            record_ids.add(record_id)
    if duplicates:
        errors.append(f"duplicate record_ids found: {', '.join(sorted(duplicates))}")

    for name, rows in rows_by_file.items():
        path = workspace / "ledger" / name
        for row in rows:
            errors.extend(validate_row(path, row, record_ids, entity_ids, event_ids))

    runs_root = workspace / "ledger" / "ingest-runs"
    if runs_root.exists():
        for run_file in sorted(runs_root.rglob("*.json")):
            try:
                payload = load_json(run_file)
            except json.JSONDecodeError as exc:
                errors.append(f"{run_file}: invalid JSON: {exc}")
                continue
            for field in RECORD_FIELDS + ["run_id", "mode", "status", "notes", "workspace_root"]:
                if field not in payload:
                    errors.append(f"{run_file}: missing field '{field}'")
            if payload.get("change_type") not in CHANGE_TYPES:
                errors.append(f"{run_file}: invalid change_type '{payload.get('change_type')}'")

    if errors:
        for line in errors:
            print(f"ERROR: {line}")
        return 1

    total_rows = sum(len(rows) for rows in rows_by_file.values())
    print(f"Validated {len(LEDGER_FILES)} ledgers and {total_rows} total rows.")
    print(f"Validated manifest: {manifest_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
