# OMEGA PROTOCOL — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# LLM backend routing
LLM_BACKEND=gemini
BACKGROUND_LLM_BACKEND=gemini
LOCAL_LLM_MODEL=
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_FORMAT=
LOCAL_LLM_TIMEOUT_SECONDS=25
LOCAL_LLM_MAX_RETRIES=1
LOCAL_LLM_KEEP_ALIVE=30m
LOCAL_LLM_MAX_PROMPT_TOKENS_ESTIMATE=2800
LOCAL_LLM_FALLBACK_TO_GEMINI_ENABLED=true
LOCAL_LLM_AUTO_PULL_ENABLED=false
LOCAL_LLM_PULL_ON_STARTUP=false
LOCAL_LLM_PULL_TIMEOUT_SECONDS=1800
CSC_STRICT_LOCAL_ONLY=false
ACTIVATION_STEERING_ENABLED=false
CSC_STEERING_MODE=scaffold
CSC_HOOKED_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
CSC_HOOKED_DEVICE=cpu
CSC_HOOKED_MAX_NEW_TOKENS=160
CSC_HOOKED_TEMPERATURE=0.7
CSC_HOOKED_SEED=1337
STEERING_VECTOR_DIM=32
STEERING_BASE_SCALE=0.35
STEERING_PRESSURE_GAIN=0.65
STEERING_WRITEBACK_ENABLED=true
# Ambient / telemetry coupling controls
AMBIENT_SENSOR_INTERVAL=60
WEATHER_INTERVAL=600
PING_INTERVAL=300
MYCELIAL_MOOD_MIN_VALID_PINGS=3
MYCELIAL_MOOD_CHOPPY_LATENCY_MS=180
MYCELIAL_MOOD_STORMY_LATENCY_MS=280
MYCELIAL_MOOD_CHOPPY_SPREAD_MS=260
MYCELIAL_MOOD_STORMY_SPREAD_MS=420
MYCELIAL_BEHAVIOR_COUPLING=0.12
MYCELIAL_PROMPT_COUPLING_ENABLED=false

# Substrate abstraction layer
SUBSTRATE_MODE=local
SUBSTRATE_ADAPTERS=local_psutil
SUBSTRATE_DISCOVERY_INTERVAL=300
SUBSTRATE_AUTO_GRAFT=false

# InfluxDB
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=omega
INFLUXDB_INIT_PASSWORD=change-me-influx-password
INFLUXDB_INIT_ORG=omega
INFLUXDB_INIT_BUCKET=somatic_history
INFLUXDB_INIT_RETENTION=72h
INFLUXDB_INIT_ADMIN_TOKEN=change-me-influx-admin-token

# PostgreSQL
POSTGRES_DB=omega
POSTGRES_USER=ghost
POSTGRES_PASSWORD=change-me-postgres-password

# Redis (no auth for local dev)
REDIS_URL=redis://redis:6379/0

# Thought quality controls (optional)
MONOLOGUE_INTERVAL=300
PROACTIVE_INITIATION_COOLDOWN_SECONDS=1800
PROACTIVE_MAX_DUPLICATE_OVERLAP=0.82
SEARCH_REPEAT_COOLDOWN_SECONDS=1800
SEARCH_RESULT_SNIPPET_MAX_CHARS=700
SEARCH_RESULT_MAX_DUPLICATE_OVERLAP=0.88
AUTONOMOUS_TOPOLOGY_ORGANIZATION_ENABLED=true
AUTONOMOUS_TOPOLOGY_MAX_CONCEPTS_PER_THOUGHT=2
AUTONOMOUS_TOPOLOGY_MAX_ENTITY_LINKS_PER_TYPE=3
AUTONOMOUS_TOPOLOGY_MIN_CONCEPT_TOKEN_COUNT=8
AUTONOMOUS_TOPOLOGY_DRIVE_INTERVAL_CYCLES=2
AUTONOMOUS_TOPOLOGY_BOOTSTRAP_ON_NOVELTY=true
AUTONOMOUS_TOPOLOGY_BOOTSTRAP_MIN_SHAPE=0.82
AUTONOMOUS_TOPOLOGY_BOOTSTRAP_MIN_WARP_DELTA=0.22

# TTS (optional; backend audio synthesis)
TTS_ENABLED=true
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
OPENAI_API_KEY=
TTS_CACHE_DIR=data/tts_cache

# Local/offline TTS (Piper primary, pyttsx3 fallback)
LOCAL_TTS_ENGINE=piper
LOCAL_TTS_MODEL_ID=en_US-lessac-medium
LOCAL_TTS_MODEL_DIR=data/tts_models/piper
LOCAL_TTS_AUTO_DOWNLOAD=true
LOCAL_TTS_VOICE_ID=
LOCAL_TTS_RATE=1.0
LOCAL_TTS_VOLUME=1.0

# Optional: secure remote share mode (HTTP Basic Auth for all UI/API routes)
SHARE_MODE_ENABLED=false
SHARE_MODE_USERNAME=omega
SHARE_MODE_PASSWORD=change-this-to-a-strong-password
# Comma-separated exact paths or prefix rules ending with *
SHARE_MODE_EXEMPT_PATHS=/health,/diagnostics/*,/dream_assets/*,/assets/site.webmanifest

# Share tunnel runtime mode:
# - quick: ephemeral trycloudflare.com URL
# - named: fixed hostname via Cloudflare named tunnel
SHARE_TUNNEL_MODE=quick
# Required when SHARE_TUNNEL_MODE=named
SHARE_TUNNEL_FIXED_HOSTNAME=
CLOUDFLARE_TUNNEL_TOKEN=

# Hallucination imagery (local diffusers)
HALLUCINATION_IMAGE_PROVIDER=pollinations
HALLUCINATION_DIFFUSERS_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
HALLUCINATION_DIFFUSERS_LOCAL_DIR=
HALLUCINATION_DIFFUSERS_DEVICE=auto
HALLUCINATION_DIFFUSERS_DTYPE=auto
HALLUCINATION_DIFFUSERS_STEPS=20
HALLUCINATION_DIFFUSERS_GUIDANCE=7.0
HALLUCINATION_DIFFUSERS_WIDTH=512
HALLUCINATION_DIFFUSERS_HEIGHT=512
HALLUCINATION_DIFFUSERS_SEED=0
HALLUCINATION_DIFFUSERS_LOCAL_ONLY=false
HF_HOME=/app/data/hf
HUGGINGFACE_HUB_TOKEN=
HF_TOKEN=

# Optional: operator token for privileged control routes
# Sent as X-Operator-Token header (or Authorization: Bearer <token>)
OPERATOR_API_TOKEN=
CONTROL_TRUSTED_CIDRS=127.0.0.1/32,::1/128,172.17.0.0/16,192.168.65.0/24
DIAGNOSTICS_TRUSTED_CIDRS=127.0.0.1/32,::1/128,172.17.0.0/16,192.168.65.0/24
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=true

# Hidden system-ops panel (logo unlock)
OPS_TEST_CODE=1NDASHE77
OPS_SNAPSHOTS_ROOT=/app/data/psych_eval

# RPD-1 reflection layer (advisory-first)
RPD_MODE=advisory
RPD_SHARED_CLARITY_THRESHOLD=0.62
RPD_TOPOLOGY_WARP_MIN=0.12
RPD_REFLECTION_BATCH=8
RPD_SHADOW_REFLECTION_AUTORUN=true
RPD_SHADOW_REFLECTION_COOLDOWN_SECONDS=90

# RRD-2 topology + resonance (3-phase rollout)
RRD2_MODE=hybrid
RRD2_ROLLOUT_PHASE=A
RRD2_HIGH_IMPACT_KEYS=self_model,philosophical_stance,understanding_of_operator,conceptual_frameworks
RRD2_MIN_SHARED_CLARITY=0.68
RRD2_MIN_DELTA=0.18
RRD2_MIN_COHESION=0.52
RRD2_MAX_NEGATIVE_RESONANCE=0.78
RRD2_DAMPING_ENABLED=true
RRD2_DAMPING_WINDOW_SIZE=8
RRD2_DAMPING_SPIKE_DELTA=0.10
RRD2_DAMPING_STRENGTH=0.45
RRD2_DAMPING_REFRACTORY_SECONDS=120
RRD2_DAMPING_REFRACTORY_BLEND=0.25

# Unified governance rollout/write-scope surfaces
GOVERNANCE_ENFORCEMENT_SURFACES=generation,actuation,messaging,identity_corrections,manifold_writes,rolodex_writes,entity_writes

# iMessage bridge (macOS host only; keep disabled by default)
IMESSAGE_BRIDGE_ENABLED=false
IMESSAGE_DB_PATH=~/Library/Messages/chat.db
IMESSAGE_POLL_INTERVAL_SECONDS=2.0
IMESSAGE_POLL_BATCH_SIZE=50
IMESSAGE_SENDER_ACCOUNT=ghost@example.com
# Optional host-side bridge for containerized backend dispatch
IMESSAGE_HOST_BRIDGE_URL=http://host.docker.internal:8765
IMESSAGE_HOST_BRIDGE_TOKEN=

# Ghost contact mode (ephemeral by default; no DB persistence)
GHOST_CONTACT_MODE_ENABLED=true
GHOST_CONTACT_PERSIST_ENABLED=false
GHOST_CONTACT_THREAD_TTL_SECONDS=86400

# External scholarly/open-data grounding
PHILOSOPHERS_API_ENABLED=true
PHILOSOPHERS_API_BASE_URL=https://philosophersapi.com
PHILOSOPHERS_API_TIMEOUT_SECONDS=8
PHILOSOPHERS_API_MAX_RESULTS=3
ARXIV_API_ENABLED=true
ARXIV_API_ENDPOINT=https://export.arxiv.org/api/query
ARXIV_API_TIMEOUT_SECONDS=10
ARXIV_API_MAX_RESULTS=3
ARXIV_API_MIN_INTERVAL_SECONDS=3
ARXIV_API_ACKNOWLEDGEMENT=Thank you to arXiv for use of its open access interoperability.
WIKIDATA_API_ENABLED=true
WIKIDATA_API_ENDPOINT=https://www.wikidata.org/w/api.php
WIKIDATA_API_TIMEOUT_SECONDS=8
WIKIDATA_API_MAX_RESULTS=3
WIKIPEDIA_API_ENABLED=true
WIKIPEDIA_API_ENDPOINT=https://en.wikipedia.org/w/api.php
WIKIPEDIA_API_TIMEOUT_SECONDS=8
WIKIPEDIA_API_MAX_RESULTS=3
OPENALEX_API_ENABLED=true
OPENALEX_API_ENDPOINT=https://api.openalex.org/works
OPENALEX_API_TIMEOUT_SECONDS=10
OPENALEX_API_MAX_RESULTS=3
OPENALEX_API_KEY=
OPENALEX_MAILTO=
CROSSREF_API_ENABLED=true
CROSSREF_API_ENDPOINT=https://api.crossref.org/works
CROSSREF_API_TIMEOUT_SECONDS=10
CROSSREF_API_MAX_RESULTS=3
CROSSREF_MAILTO=
GROUNDING_TOTAL_BUDGET_MS=1200
GROUNDING_ADAPTER_TIMEOUT_MS=800

# Predictive affective governor
PREDICTIVE_GOVERNOR_ENABLED=true
PREDICTIVE_GOVERNOR_INTERVAL_SECONDS=5
PREDICTIVE_GOVERNOR_WINDOW_SIZE=24
PREDICTIVE_GOVERNOR_HORIZON_SECONDS=120
PREDICTIVE_GOVERNOR_WATCH_THRESHOLD=0.58
PREDICTIVE_GOVERNOR_PREEMPT_THRESHOLD=0.76

# Experiment + ablation artifacts
EXPERIMENT_ARTIFACTS_DIR=backend/data/experiments
EXPERIMENT_DEFAULT_REPEATS=1
EXPERIMENT_DEFAULT_SEED=1337

# Natural Cognitive Friction
NATURAL_COGNITIVE_FRICTION=true

# Unified mutation policy
MUTATION_UNDO_TTL_SECONDS=900
